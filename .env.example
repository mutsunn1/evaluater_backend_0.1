# Database
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=evaluator_db
DATABASE_URL=postgresql+asyncpg://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# Elasticsearch (mid-term memory)
ES_HOST=localhost
ES_PORT=9200
ES_INDEX=mid_term_memory

# LLM Configuration
DEFAULT_LLM_API_KEY=sk-your-key-here
DEFAULT_LLM_BASE_URL=https://api.openai.com/v1
DEFAULT_LLM_MODEL_NAME=gpt-4o-mini

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
